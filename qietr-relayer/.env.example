# Server
PORT=4080
HOST=0.0.0.0
LOG_LEVEL=info

# Upstream Kora instance
KORA_URL=http://localhost:3000

# Fee-payer keypair — base58 of a 64-byte secret-key array. NEVER commit.
# In production this is HSM-resident; the env var is dev-only.
FEE_PAYER_KEYPAIR=

# Optional rate-limit overrides
RATE_LIMIT_IP_PER_10MIN=30
RATE_LIMIT_RECIPIENT_PER_10MIN=10

# Sanctions list source (file path or URL)
SANCTIONS_LIST=./data/sanctions.example.txt
