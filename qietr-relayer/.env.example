# Server
PORT=4080
# Bind to 127.0.0.1 unless API_KEY is set. On 0.0.0.0 with no API_KEY the relayer
# logs a SECURITY warning — anyone could spend the fee-payer's SOL.
HOST=0.0.0.0
LOG_LEVEL=info

# Set true ONLY when fronted by a trusted proxy/CDN, so req.ip (and the
# rate-limit bucket) reflects the real client via X-Forwarded-For.
TRUST_PROXY=false

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=4XH6f74UFTvqx4j9UarXGrRZRrAwbnNNsRFBTfNqmWib

# Fee-payer keypair — JSON array of 64 bytes or base58 string. NEVER commit.
# In production this is HSM-resident; the env var is dev-only.
FEE_PAYER_SECRET_KEY=

# API key for Bearer auth on all endpoints (except /health).
# If unset, auth is disabled (dev mode).
API_KEY=

# Fee ATA where gasless deposit fees are collected (required for /deposit-quote)
FEE_ATA=

# Fixed fee in micro-USDC charged per gasless deposit
FEE_AMOUNT_MICRO=50000

# Fee basis points charged per withdraw (default 50 = 0.5%)
FEE_BPS=50

# Optional upstream Kora instance
KORA_URL=

# Tier table as JSON
# DENOM_TIERS=[{"denomId":0,"amountMicroUsdc":"100000"},{"denomId":1,"amountMicroUsdc":"1000000"},{"denomId":2,"amountMicroUsdc":"10000000"},{"denomId":3,"amountMicroUsdc":"100000000"}]

# Rate-limit overrides (defaults: IP=20/min, recipient=10/min)
RATE_IP_LIMIT=20
RATE_IP_WINDOW=60
RATE_RECIPIENT_LIMIT=10
RATE_RECIPIENT_WINDOW=60

# Sanctions list source (file path or URL). If set but it fails to load on
# startup, the relayer refuses to start (fail-closed).
SANCTIONS_LIST=

# --- Money-path guards ---
# Refuse to forward (and spend SOL) when the fee-payer balance drops below this
# many lamports. Default ~0.05 SOL.
MIN_BALANCE_LAMPORTS=50000000
# Cap on forwarded (SOL-spending) txs per rolling window, across all callers.
MAX_TX_PER_WINDOW=200
SPEND_WINDOW_SECONDS=60
# Replay-guard TTL (seconds). Must exceed blockhash validity (~60-90s).
REPLAY_TTL_SECONDS=120
