# Cloudflare Pages headers. Copied verbatim into the static export (out/).
#
# The browser SDK runs the snarkjs Groth16 prover in-page (WebAssembly +
# web workers) and fetches:
#   - circuit artifacts from /circuits (same origin)
#   - merkle proofs from the indexer API   (NEXT_PUBLIC_QIETR_INDEXER_URL)
#   - account state from the Solana RPC     (NEXT_PUBLIC_QIETR_RPC_URL)
#   - optionally the relayer                (NEXT_PUBLIC_QIETR_RELAYER_URL)
#
# CSP must therefore allow `wasm-unsafe-eval`, `worker-src blob:`, and the
# cross-origin hosts in connect-src. EDIT the connect-src host list below to
# match YOUR deployed indexer / relayer / RPC domains, then redeploy.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; worker-src 'self' blob:; connect-src 'self' https://*.helius-rpc.com https://*.solana.com https://api.devnet.solana.com https://*.onrender.com https://*.vercel.app; frame-ancestors 'none'; base-uri 'self'

# Long-cache the immutable circuit artifacts.
/circuits/*
  Cache-Control: public, max-age=31536000, immutable
