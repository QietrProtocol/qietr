# Qietr Web — Environment Variables
# Copy to .env.local for local development.

# Solana cluster: mainnet-beta | devnet | localnet
NEXT_PUBLIC_QIETR_CLUSTER=devnet

# RPC endpoint. Use a dedicated provider (Helius) — the public devnet RPC is
# rate-limited and getProgramAccounts/getSignaturesForAddress will throttle.
NEXT_PUBLIC_QIETR_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# Indexer API base URL (required for proof generation, nullifier checks).
# Your deployed indexer, e.g. https://qietr-indexer-api.fly.dev
NEXT_PUBLIC_QIETR_INDEXER_URL=https://qietr-indexer-api.fly.dev

# Relayer URL (optional — only for gasless deposits)
NEXT_PUBLIC_QIETR_RELAYER_URL=

# Circuit artifact base URL (WASM + zkey). Artifacts are bundled under
# public/circuits, so the same-origin path below works out of the box.
NEXT_PUBLIC_QIETR_PROVER_PATH=/circuits
