# Qietr Web — Environment Variables
# Copy to .env.local for local development.

# Solana cluster: mainnet-beta | devnet | localnet
NEXT_PUBLIC_QIETR_CLUSTER=devnet

# Optional RPC override (defaults to cluster default)
NEXT_PUBLIC_QIETR_RPC_URL=

# Indexer API base URL (required for proof generation, nullifier checks)
NEXT_PUBLIC_QIETR_INDEXER_URL=

# Relayer URL (required for gasless deposits)
NEXT_PUBLIC_QIETR_RELAYER_URL=

# Circuit artifact base URL (WASM + zkey files)
NEXT_PUBLIC_QIETR_PROVER_PATH=
