# qietr-indexer poller — environment

# Solana RPC (Helius devnet shown; any standard RPC works)
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# Pool program (defaults to the deployed devnet ID if unset)
PROGRAM_ID=4XH6f74UFTvqx4j9UarXGrRZRrAwbnNNsRFBTfNqmWib

# Postgres. Neon example — note sslmode=require (TLS auto-enabled).
DATABASE_URL=postgres://user:pass@ep-xxx.region.aws.neon.tech/qietr?sslmode=require

# Optional: force TLS on/off independent of the URL (require | disable)
# PGSSL=require
# Optional: verify the server cert against a CA bundle instead of skipping
# PGSSL_CA=/path/to/neon-ca.pem

# Optional tuning
# POLL_INTERVAL_MS=8000
# POLLER_COMPONENT=poller-devnet
